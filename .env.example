# Database
export DATABASE_URL=postgresql://mira:mira@localhost:5432/mira

# GitHub App
export MIRA_GITHUB_APP_ID=123456
export MIRA_GITHUB_PRIVATE_KEY_PATH=./private-key.pem
export MIRA_WEBHOOK_SECRET=your_webhook_secret_here
# Optional: override for GitHub Enterprise Server.
# Examples:
#   export MIRA_GITHUB_API_URL=https://github.acme-corp.com/api/v3
#   export MIRA_GITHUB_GRAPHQL_URL=https://github.acme-corp.com/api/graphql
# Optional: bot login override for self-checks. Defaults to "miracodeai".
# export MIRA_BOT_NAME=miracodeai

# LLM (OpenRouter)
export OPENROUTER_API_KEY=sk-or-v1-your-key-here
export MIRA_MODEL=anthropic/claude-sonnet-4-6

# Dashboard
export ADMIN_PASSWORD=changeme
export MIRA_INDEX_DIR=./data/indexes
